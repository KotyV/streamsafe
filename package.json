{
  "name": "streamsafe",
  "displayName": "StreamSafe",
  "description": "Automatically protect sensitive files (.env, secrets) while streaming by toggling an OBS source that covers VS Code.",
  "version": "0.1.0",
  "publisher": "KotyV",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/KotyV/streamsafe"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "keywords": [
    "obs",
    "stream",
    "twitch",
    "security",
    "env",
    "secrets",
    "privacy"
  ],
  "icon": "assets/icon.png",
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "StreamSafe",
      "properties": {
        "streamsafe.obsWebSocketUrl": {
          "type": "string",
          "default": "ws://localhost:4455",
          "description": "OBS WebSocket server URL (v5)"
        },
        "streamsafe.obsWebSocketPassword": {
          "type": "string",
          "default": "",
          "description": "OBS WebSocket password (leave empty if none)"
        },
        "streamsafe.sensitivePatterns": {
          "type": "array",
          "default": [
            "**/.env",
            "**/.env.*",
            "**/.env.local",
            "**/.env.production",
            "**/secrets.*",
            "**/credentials.*",
            "**/*.pem",
            "**/*.key",
            "**/*secret*",
            "**/*password*"
          ],
          "description": "Glob patterns for files considered sensitive"
        },
        "streamsafe.obsSourceName": {
          "type": "string",
          "default": "StreamSafe_Cover",
          "description": "OBS source name to toggle for covering the screen"
        },
        "streamsafe.obsSceneName": {
          "type": "string",
          "default": "",
          "description": "OBS scene name (leave empty for the active scene)"
        },
        "streamsafe.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable/disable StreamSafe"
        },
        "streamsafe.showNotifications": {
          "type": "boolean",
          "default": true,
          "description": "Show notifications when StreamSafe covers/uncovers the screen"
        }
      }
    },
    "commands": [
      {
        "command": "streamsafe.toggle",
        "title": "StreamSafe: Toggle"
      },
      {
        "command": "streamsafe.reconnect",
        "title": "StreamSafe: Reconnect to OBS"
      },
      {
        "command": "streamsafe.status",
        "title": "StreamSafe: Show Status"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "lint": "eslint src --ext ts",
    "package": "vsce package",
    "publish": "vsce publish"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3",
    "@vscode/vsce": "^2.22.0"
  },
  "dependencies": {
    "obs-websocket-js": "^5.0.6",
    "minimatch": "^9.0.3"
  }
}
